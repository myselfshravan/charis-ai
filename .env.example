# ─────────────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS (read by server/index.js — NEVER bundled into the browser)
# These must NOT have the VITE_ prefix, or Vite would expose them to the client.
# ─────────────────────────────────────────────────────────────────────────

# Your Groq API key — https://console.groq.com/keys
GROQ_API_KEY=

# Groq API base URL (OpenAI-compatible). Leave as-is unless told otherwise.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model that runs the agent. Use openai/gpt-oss-120b — it's the most reliable
# at MCP tool calls. Avoid llama-3.3-70b-versatile and gpt-oss-20b: they
# intermittently emit malformed tool calls (Groq rejects them as tool_use_failed).
GROQ_MODEL=openai/gpt-oss-120b

# fashion-explore MCP server + its bearer token.
MCP_URL=https://fashion-mcp.droidvm.dev/mcp
MCP_AUTH_TOKEN=

# Port the backend listens on (the Vite dev proxy forwards /api here).
PORT=8787

# PostHog analytics (optional). Runs only in production (NODE_ENV=production,
# e.g. on Vercel). Stays OFF in local dev so flaky networks don't spam errors.
# Set POSTHOG_LOCAL=1 to force it on locally. Empty key = always off.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND (safe to expose). The browser calls this path; Vite proxies it to
# the backend in dev. Leave empty to use the offline stub instead.
# ─────────────────────────────────────────────────────────────────────────
VITE_API_URL=/api/chat
